//@version=6
indicator("ORB + FVG [NY]", overlay=true,
          max_lines_count=500, max_labels_count=500, max_boxes_count=500)

// ─────────────────────────────────────────────────────────────────────────────
//  INPUTS
// ─────────────────────────────────────────────────────────────────────────────
var string G1 = "⏱  ORB Period  ·  All times: America / New_York"
var string G2 = "📐  Lines"
var string G3 = "🏷  Labels"
var string G4 = "🟦  Zone"
var string G5 = "📊  FVG"
var string G6 = "📊  FVG Ext"
var string G7 = "📋  Status Table"

// ── ORB period ────────────────────────────────────────────────────────────────
i_orbPeriod = input.string(
     "5-min  (9:30 – 9:35)",
     "ORB Period",
     options  = ["5-min  (9:30 – 9:35)", "15-min  (9:30 – 9:45)"],
     tooltip  = "Captures the exact High / Low of the first candle of the NY session.\n• 5-min  → single 9:30–9:35 AM candle\n• 15-min → single 9:30–9:45 AM candle\nAll times are New York (America/New_York).",
     group    = G1)

// ── Lines ─────────────────────────────────────────────────────────────────────
i_highColor = input.color(color.new(#26a69a, 0), "High Line Color", group=G2)
i_lowColor  = input.color(color.new(#ef5350, 0), "Low Line Color",  group=G2)
i_lWidth    = input.int  (2, "Line Width", minval=1, maxval=4,       group=G2)
i_lStyle    = input.string("Solid", "Line Style",
     options = ["Solid","Dashed","Dotted"],                           group=G2)

// ── Labels ────────────────────────────────────────────────────────────────────
i_showLbl   = input.bool  (true,   "Show Labels",                    group=G3)
i_lblHText  = input.string("ORBH", "High Label Text",                group=G3)
i_lblLText  = input.string("ORBL", "Low Label Text",                 group=G3)
i_lblHPos   = input.string("Right","High Label H-Position",
     options = ["Left","Center","Right"],                             group=G3)
i_lblLPos   = input.string("Right","Low Label H-Position",
     options = ["Left","Center","Right"],                             group=G3)
i_lblVAlign = input.string("Middle","Label Vertical Alignment",
     options = ["Top","Middle","Bottom"],                             group=G3)
i_lblSize   = input.string("Small", "Label Size",
     options = ["Tiny","Small","Normal","Large"],                     group=G3)

// ── Zone ──────────────────────────────────────────────────────────────────────
i_showZone  = input.bool(true, "Show ORB Zone",                      group=G4)
i_zoneAlpha = input.int (90,   "Zone Transparency",
     minval=50, maxval=99,                                            group=G4)

// ── FVG ───────────────────────────────────────────────────────────────────────
i_fvgBoxLen   = input.int  (22, "Box Length", minval=1,              group=G5)
i_fvgBullCol  = input.color(color.new(color.green, 90),
                            "Bull Color",                            group=G5)
i_fvgBearCol  = input.color(color.new(color.red, 90),
                            "Bear Color",                            group=G5)
i_fvgSession  = input.session("0930-1200", "FVG Session (NY)",
     tooltip = "New York session when FVG detection starts.\nNew FVGs are detected from session start until the ORB breaks.\nAll remaining FVGs are deleted when the session ends.",
                                                                      group=G5)
i_maxFvgs     = input.int  (100, "Max Tracked FVGs",
     minval=1, maxval=500,
     tooltip = "Maximum number of simultaneous FVG boxes on chart.\nWhen the limit is reached, the oldest FVG is removed to make room for new ones.",
                                                                      group=G5)

// ── FVG Ext ───────────────────────────────────────────────────────────────────
i_extEnabled   = input.bool  (true,   "Enabled",
     tooltip = "Draw extension line when the 2nd candle's extreme lies\noutside the FVG gap (not contained between top & bottom).",
                                                                      group=G6)
i_extLen       = input.int   (22,     "Line Length",
     minval=1,
     tooltip = "Number of bars the extension line spans to the right.",
                                                                      group=G6)
i_extWidth     = input.int   (1,      "Line Width",
     minval=1, maxval=4,                                              group=G6)
i_extStyle     = input.string("Solid", "Line Style",
     options = ["Solid","Dashed","Dotted"],                           group=G6)

// ── Status Table ──────────────────────────────────────────────────────────────
i_showST    = input.bool  (false, "Show Status Table",                group=G7)


// ─────────────────────────────────────────────────────────────────────────────
//  DERIVED CONSTANTS
// ─────────────────────────────────────────────────────────────────────────────
NY = "America/New_York"

orbEndMin = i_orbPeriod == "5-min  (9:30 – 9:35)"  ? 35  : 45


// ─────────────────────────────────────────────────────────────────────────────
//  HELPER FUNCTIONS
// ─────────────────────────────────────────────────────────────────────────────
f_ls() =>
    i_lStyle == "Dashed" ? line.style_dashed  :
     i_lStyle == "Dotted" ? line.style_dotted : line.style_solid

f_sz() =>
    i_lblSize == "Tiny"   ? size.tiny   :
     i_lblSize == "Normal" ? size.normal :
     i_lblSize == "Large"  ? size.large  : size.small

f_vStyle() =>
    switch i_lblVAlign
        "Top"    => label.style_label_down
        "Bottom" => label.style_label_up
        =>          label.style_label_center

f_extStyle() =>
    i_extStyle == "Dashed" ? line.style_dashed  :
     i_extStyle == "Dotted" ? line.style_dotted : line.style_solid

f_lx(pos, s, e) =>
    switch pos
        "Left"   => s
        "Center" => math.round((s + e) / 2)
        =>          e


// ─────────────────────────────────────────────────────────────────────────────
//  CURRENT-BAR TIME  (chart timeframe, assumed 1-min)
// ─────────────────────────────────────────────────────────────────────────────
nyH = hour      (time, NY)
nyM = minute    (time, NY)
nyD = dayofmonth(time, NY)

// ORB windows
inORBWindow = nyH == 9 and nyM >= 30 and nyM < orbEndMin
pastORB     = (nyH == 9 and nyM >= orbEndMin) or nyH > 9

// FVG window — uses input.session() for a clean time-range picker UI
inFVGWindow = not na(time(timeframe.period, i_fvgSession, NY))


// ─────────────────────────────────────────────────────────────────────────────
//  PERSISTENT STATE
// ─────────────────────────────────────────────────────────────────────────────
// --- ORB state ---
var float    orbH            = na
var float    orbL            = na
var bool     drawn           = false
var bool     stopped         = false
var int      startBar        = na
var int      sessionStartBar = na
var line     lnH             = na
var line     lnL             = na
var label    lbH             = na
var label    lbL             = na
var linefill zFill           = na

// --- FVG state ---
var array<box>   fvgBoxes      = array.new<box>()
var array<label> fvgLabels     = array.new<label>()
var array<float> fvgTops       = array.new<float>()
var array<float> fvgBots       = array.new<float>()
var array<bool>  fvgIsBulls    = array.new<bool>()
var array<line>  fvgExtLines   = array.new<line>()
var bool         fvgWasActive  = false

// --- Pending FVG (drawn on bar open, confirmed/deleted on bar close) ---
var box   pendingBox   = na
var label pendingLabel = na
var line  pendingExt   = na
var float pendingTop   = na
var float pendingBot   = na

// --- Breakout tracking ---
var float candleCover = na
var float candleEntry = na
var int   orbBreakDir = 0        // 0=unbroken, 1=broke high, -1=broke low
var int   brokeTime    = na

// --- FVG snapshot (captured at ORB break, persists through mitigation) ---
var float snFvgCover  = na
var float snFvgExt    = na
var bool  snFvgHasExt = false

// --- Persistent TP values (computed at breakout, used by hit detection) ---
var float candleTP  = na
var float fvgTP     = na
var float fvgExtTP  = na

// --- Hit tracking (first-touch per level, per pair) ---
var bool  candleCoverHit     = false
var int   candleCoverHitTime = na
var bool  candleTPHit        = false
var int   candleTPHitTime    = na

var bool  fvgCoverHit        = false
var int   fvgCoverHitTime    = na
var bool  fvgTPHit           = false
var int   fvgTPHitTime       = na

var bool  fvgExtCoverHit     = false
var int   fvgExtCoverHitTime = na
var bool  fvgExtTPHit        = false
var int   fvgExtTPHitTime    = na

// --- Hit tracking is per-level, independent — no locking, no entry threshold ---
// Each level records its FIRST touch time after ORB breaks. The AI skill handles
// entry-time logic (comparing hit times against entry = brokeTime + 1h).

// --- Status Table ---
var table statusTbl = table.new(position.bottom_left, 2, 20)


// ─────────────────────────────────────────────────────────────────────────────
//  RESET  ─  new trading day
// ─────────────────────────────────────────────────────────────────────────────
if nyD != nyD[1]
    // --- Delete old ORB drawings ---
    if not na(lnH)
        line.delete(lnH)
        line.delete(lnL)
    if not na(lbH)
        label.delete(lbH)
        label.delete(lbL)
    if not na(zFill)
        linefill.delete(zFill)

    orbH            := na
    orbL            := na
    drawn           := false
    stopped         := false
    startBar        := na
    sessionStartBar := na
    lnH             := na
    lnL             := na
    lbH             := na
    lbL             := na
    zFill           := na

    candleCover     := na
    candleEntry     := na
    orbBreakDir     := 0
    brokeTime       := na

    snFvgCover      := na
    snFvgExt        := na
    snFvgHasExt     := false

    pendingBox      := na
    pendingLabel    := na
    pendingExt      := na

    if array.size(fvgBoxes) > 0
        for i = 0 to array.size(fvgBoxes) - 1
            box.delete(array.get(fvgBoxes, i))
            label.delete(array.get(fvgLabels, i))
            if not na(array.get(fvgExtLines, i))
                line.delete(array.get(fvgExtLines, i))
    array.clear(fvgBoxes)
    array.clear(fvgLabels)
    array.clear(fvgTops)
    array.clear(fvgBots)
    array.clear(fvgIsBulls)
    array.clear(fvgExtLines)
    fvgWasActive := false

    candleTP           := na
    fvgTP              := na
    fvgExtTP           := na

    candleCoverHit     := false
    candleCoverHitTime := na
    candleTPHit        := false
    candleTPHitTime    := na

    fvgCoverHit        := false
    fvgCoverHitTime    := na
    fvgTPHit           := false
    fvgTPHitTime       := na

    fvgExtCoverHit     := false
    fvgExtCoverHitTime := na
    fvgExtTPHit        := false
    fvgExtTPHitTime    := na



// ═════════════════════════════════════════════════════════════════════════════
//  ORB — Opening Range Breakout
// ═════════════════════════════════════════════════════════════════════════════

// ── STEP 0  —  Record the 9:30 bar_index ──────────────────────────────────
if nyH == 9 and nyM == 30 and na(sessionStartBar)
    sessionStartBar := bar_index

// ── STEP 1  —  Accumulate the ORB High / Low ──────────────────────────────
if inORBWindow and not drawn
    orbH := na(orbH) ? high : math.max(orbH, high)
    orbL := na(orbL) ? low  : math.min(orbL, low)

// ── STEP 2  —  Draw lines & labels ────────────────────────────────────────
if pastORB and not drawn and not na(orbH) and not na(orbL)
    drawn    := true
    startBar := not na(sessionStartBar) ? sessionStartBar : bar_index

    lnH := line.new(startBar, orbH, bar_index + 1, orbH,
         color=i_highColor, width=i_lWidth, style=f_ls(), extend=extend.right)
    lnL := line.new(startBar, orbL, bar_index + 1, orbL,
         color=i_lowColor,  width=i_lWidth, style=f_ls(), extend=extend.right)

    if i_showZone
        zFill := linefill.new(lnH, lnL, color.new(color.gray, i_zoneAlpha))

    if i_showLbl
        lbH := label.new(
             x         = startBar,
             y         = orbH,
             text      = i_lblHText,
             color     = chart.bg_color,
             textcolor = i_highColor,
             style     = f_vStyle(),
             size      = f_sz())
        lbL := label.new(
             x         = startBar,
             y         = orbL,
             text      = i_lblLText,
             color     = chart.bg_color,
             textcolor = i_lowColor,
             style     = f_vStyle(),
             size      = f_sz())

// ── STEP 3  —  Update label X positions every bar ─────────────────────────
if drawn and not stopped and i_showLbl
    if not na(lbH)
        label.set_x(lbH, f_lx(i_lblHPos, startBar, bar_index))
    if not na(lbL)
        label.set_x(lbL, f_lx(i_lblLPos, startBar, bar_index))

// ── STEP 4  —  Breakout detection ─────────────────────────────────────────
if drawn and not stopped and barstate.isconfirmed
    if close > orbH or close < orbL
        stopped := true
        brokeTime := time

        int fvgCount = array.size(fvgBoxes)
        if fvgCount > 0
            int   lastIdx   = fvgCount - 1
            float lastTop   = array.get(fvgTops,    lastIdx)
            float lastBot   = array.get(fvgBots,    lastIdx)
            bool  lastBull  = array.get(fvgIsBulls, lastIdx)
            line  lastExt   = array.get(fvgExtLines, lastIdx)
            snFvgCover := lastBull ? lastBot - 0.25 : lastTop + 0.25
            if not na(lastExt)
                float extPrice = line.get_y1(lastExt)
                snFvgExt    := lastBull ? extPrice - 0.25 : extPrice + 0.25
                snFvgHasExt := true
            else
                snFvgExt    := na
                snFvgHasExt := false
        else
            snFvgCover  := na
            snFvgExt    := na
            snFvgHasExt := false

        if close > orbH
            candleCover := low - 0.25
            candleEntry := close
            orbBreakDir := 1
        else if close < orbL
            candleCover := high + 0.25
            candleEntry := close
            orbBreakDir := -1

        if orbBreakDir == 1
            candleTP := candleEntry + 2 * (candleEntry - candleCover)
        else
            candleTP := candleEntry - 2 * (candleCover - candleEntry)

        if not na(snFvgCover)
            if orbBreakDir == 1
                fvgTP := candleEntry + 2 * (candleEntry - snFvgCover)
            else
                fvgTP := candleEntry - 2 * (snFvgCover - candleEntry)

        if snFvgHasExt and not na(snFvgExt)
            if orbBreakDir == 1
                fvgExtTP := candleEntry + 2 * (candleEntry - snFvgExt)
            else
                fvgExtTP := candleEntry - 2 * (snFvgExt - candleEntry)

        line.set_extend(lnH, extend.none)
        line.set_extend(lnL, extend.none)
        line.set_x2    (lnH, bar_index)
        line.set_x2    (lnL, bar_index)

        if i_showLbl
            if not na(lbH)
                label.set_x(lbH, f_lx(i_lblHPos, startBar, bar_index))
            if not na(lbL)
                label.set_x(lbL, f_lx(i_lblLPos, startBar, bar_index))


// ═════════════════════════════════════════════════════════════════════════════
//  FVG PENDING — Draw on bar open, confirm/adjust/delete on bar close
// ═════════════════════════════════════════════════════════════════════════════
if barstate.isnew and bar_index >= 2
    if inFVGWindow and not stopped[1]
        isBullOpen = high[2] < low
        isBearOpen = low[2] > high

        if isBullOpen or isBearOpen
            pendingTop := isBullOpen ? low : low[2]
            pendingBot := isBullOpen ? high[2] : high

            pendingBox := box.new(
                left         = bar_index[2],
                right        = bar_index[2] + i_fvgBoxLen,
                top          = pendingTop,
                bottom       = pendingBot,
                bgcolor      = isBullOpen ? i_fvgBullCol : i_fvgBearCol,
                border_color = isBullOpen ? i_fvgBullCol : i_fvgBearCol)

            pendingLabel := label.new(
                x         = bar_index[2] + math.max(1, i_fvgBoxLen - 3),
                y         = (pendingTop + pendingBot) / 2,
                text      = "FVG",
                color     = color.new(color.white, 100),
                style     = label.style_label_center,
                textcolor = isBullOpen ? color.green : color.red,
                size      = size.small,
                textalign = text.align_right)

            if i_extEnabled
                extLevel = isBullOpen ? low[1] : high[1]
                if extLevel < pendingBot or extLevel > pendingTop
                    pendingExt := line.new(
                        bar_index[1], extLevel,
                        bar_index[1] + i_extLen, extLevel,
                        color = isBullOpen ? i_fvgBullCol : i_fvgBearCol,
                        width = i_extWidth,
                        style = f_extStyle())

// ═════════════════════════════════════════════════════════════════════════════
//  FVG — Fair Value Gap (multi-track, ORB-break gated)
// ═════════════════════════════════════════════════════════════════════════════
if bar_index >= 2 and barstate.isconfirmed

    // ── Session tracking ─────────────────────────────────────────────────
    if inFVGWindow
        fvgWasActive := true

    // ── End-time cleanup: delete ALL remaining FVGs when session ends ─────
    if fvgWasActive and not inFVGWindow and array.size(fvgBoxes) > 0
        for i = 0 to array.size(fvgBoxes) - 1
            box.delete(array.get(fvgBoxes, i))
            label.delete(array.get(fvgLabels, i))
            if not na(array.get(fvgExtLines, i))
                line.delete(array.get(fvgExtLines, i))
        array.clear(fvgBoxes)
        array.clear(fvgLabels)
        array.clear(fvgTops)
        array.clear(fvgBots)
        array.clear(fvgIsBulls)
        array.clear(fvgExtLines)

    // ── Mitigation: remove individual FVGs whose gap zone is traded into ──
    if array.size(fvgBoxes) > 0
        i = array.size(fvgBoxes) - 1
        while i >= 0
            top  = array.get(fvgTops,    i)
            bot  = array.get(fvgBots,    i)
            bull = array.get(fvgIsBulls, i)

            mitigated = (bull and close < bot) or (not bull and close > top)

            if mitigated
                box.delete(array.get(fvgBoxes, i))
                label.delete(array.get(fvgLabels, i))
                if not na(array.get(fvgExtLines, i))
                    line.delete(array.get(fvgExtLines, i))
                array.remove(fvgBoxes,   i)
                array.remove(fvgLabels,  i)
                array.remove(fvgTops,    i)
                array.remove(fvgBots,    i)
                array.remove(fvgIsBulls, i)
                array.remove(fvgExtLines,i)
            i -= 1

    // ── Resolve pending FVG drawn on bar open ────────────────────────────
    if not na(pendingBox)
        isBullClose = high[2] < low
        isBearClose = low[2] > high

        if isBullClose or isBearClose
            finalTop = isBullClose ? low : low[2]
            finalBot = isBullClose ? high[2] : high

            box.set_top(pendingBox, finalTop)
            box.set_bottom(pendingBox, finalBot)
            box.set_bgcolor(pendingBox, isBullClose ? i_fvgBullCol : i_fvgBearCol)
            box.set_border_color(pendingBox, isBullClose ? i_fvgBullCol : i_fvgBearCol)
            label.set_y(pendingLabel, (finalTop + finalBot) / 2)
            label.set_textcolor(pendingLabel, isBullClose ? color.green : color.red)

            if not na(pendingExt)
                line.delete(pendingExt)
            line newExtLine = na
            if i_extEnabled
                extLevel = isBullClose ? low[1] : high[1]
                if extLevel < finalBot or extLevel > finalTop
                    newExtLine := line.new(
                        bar_index[1], extLevel,
                        bar_index[1] + i_extLen, extLevel,
                        color = isBullClose ? i_fvgBullCol : i_fvgBearCol,
                        width = i_extWidth,
                        style = f_extStyle())

            if array.size(fvgBoxes) >= i_maxFvgs
                box.delete(array.get(fvgBoxes, 0))
                label.delete(array.get(fvgLabels, 0))
                if not na(array.get(fvgExtLines, 0))
                    line.delete(array.get(fvgExtLines, 0))
                array.remove(fvgBoxes,    0)
                array.remove(fvgLabels,   0)
                array.remove(fvgTops,     0)
                array.remove(fvgBots,     0)
                array.remove(fvgIsBulls,  0)
                array.remove(fvgExtLines, 0)

            array.push(fvgBoxes,    pendingBox)
            array.push(fvgLabels,   pendingLabel)
            array.push(fvgTops,     finalTop)
            array.push(fvgBots,     finalBot)
            array.push(fvgIsBulls,  isBullClose)
            array.push(fvgExtLines, newExtLine)
        else
            box.delete(pendingBox)
            label.delete(pendingLabel)
            if not na(pendingExt)
                line.delete(pendingExt)

        pendingBox   := na
        pendingLabel := na
        pendingExt   := na
        pendingTop   := na
        pendingBot   := na

    // ── Detection: find new FVGs (historical bars or when no pending FVG) ─
    else if inFVGWindow and not stopped[1]

        isBull = high[2] < low
        isBear = low[2] > high

        if isBull or isBear

            // FIFO cap: remove oldest FVG if at the limit
            if array.size(fvgBoxes) >= i_maxFvgs
                box.delete(array.get(fvgBoxes, 0))
                label.delete(array.get(fvgLabels, 0))
                if not na(array.get(fvgExtLines, 0))
                    line.delete(array.get(fvgExtLines, 0))
                array.remove(fvgBoxes,    0)
                array.remove(fvgLabels,   0)
                array.remove(fvgTops,     0)
                array.remove(fvgBots,     0)
                array.remove(fvgIsBulls,  0)
                array.remove(fvgExtLines, 0)

            top = isBull ? low : low[2]
            bot = isBull ? high[2] : high

            newBox = box.new(
                left         = bar_index[2],
                right        = bar_index[2] + i_fvgBoxLen,
                top          = top,
                bottom       = bot,
                bgcolor      = isBull ? i_fvgBullCol : i_fvgBearCol,
                border_color = isBull ? i_fvgBullCol : i_fvgBearCol
            )

            newLabel = label.new(
                x         = bar_index[2] + math.max(1, i_fvgBoxLen - 3),
                y         = (top + bot) / 2,
                text      = "FVG",
                color     = color.new(color.white, 100),
                style     = label.style_label_center,
                textcolor = isBull ? color.green : color.red,
                size      = size.small,
                textalign = text.align_right
            )

            // FVG extension line: 2nd candle extreme outside the FVG gap
            line newExtLine = na
            if i_extEnabled
                extLevel = isBull ? low[1] : high[1]
                if extLevel < bot or extLevel > top
                    newExtLine := line.new(
                        bar_index[1],
                        extLevel,
                        bar_index[1] + i_extLen,
                        extLevel,
                        color = isBull ? i_fvgBullCol : i_fvgBearCol,
                        width = i_extWidth,
                        style = f_extStyle()
                    )

            array.push(fvgBoxes,    newBox)
            array.push(fvgLabels,   newLabel)
            array.push(fvgTops,     top)
            array.push(fvgBots,     bot)
            array.push(fvgIsBulls,  isBull)
            array.push(fvgExtLines, newExtLine)


// ═════════════════════════════════════════════════════════════════════════════
//  HIT DETECTION  —  first-touch per level, mutual exclusion per pair
// ═════════════════════════════════════════════════════════════════════════════
if stopped and barstate.isconfirmed

    float cv      = candleCover
    float cTP     = candleTP
    bool  isLong  = orbBreakDir == 1
    bool  isShort = orbBreakDir == -1

    // ── Candle Cover (first touch) ──
    if not candleCoverHit
        if (isLong and low <= cv) or (isShort and high >= cv)
            candleCoverHit     := true
            candleCoverHitTime := time

    // ── Candle TP (first touch) ──
    if not candleTPHit
        if (isLong and high >= cTP) or (isShort and low <= cTP)
            candleTPHit        := true
            candleTPHitTime    := time

    // ── FVG Cover (first touch, only if snapshot exists) ──
    if not na(snFvgCover) and not fvgCoverHit
        float fc = snFvgCover
        if (isLong and low <= fc) or (isShort and high >= fc)
            fvgCoverHit     := true
            fvgCoverHitTime := time

    // ── FVG TP (first touch, only if snapshot exists) ──
    if not na(snFvgCover) and not fvgTPHit
        if (isLong and high >= fvgTP) or (isShort and low <= fvgTP)
            fvgTPHit        := true
            fvgTPHitTime    := time

    // ── FVG Ext Cover (first touch, only if ext snapshot exists) ──
    if snFvgHasExt and not na(snFvgExt) and not fvgExtCoverHit
        float fe = snFvgExt
        if (isLong and low <= fe) or (isShort and high >= fe)
            fvgExtCoverHit     := true
            fvgExtCoverHitTime := time

    // ── FVG EXT TP (first touch, only if ext snapshot exists) ──
    if snFvgHasExt and not na(snFvgExt) and not fvgExtTPHit
        if (isLong and high >= fvgExtTP) or (isShort and low <= fvgExtTP)
            fvgExtTPHit        := true
            fvgExtTPHitTime    := time


// ═════════════════════════════════════════════════════════════════════════════
//  STATUS TABLE  —  hidden by default, data accessible via MCP
// ═════════════════════════════════════════════════════════════════════════════
if barstate.isconfirmed
    color stTextCol = i_showST ? color.white : color.new(color.white, 100)
    table.set_bgcolor(statusTbl, i_showST ? color.new(color.black, 80) : color.new(color.black, 100))
    table.set_border_width(statusTbl, i_showST ? 1 : 0)
    table.set_frame_width(statusTbl, i_showST ? 1 : 0)

    int row = 0
    table.cell(statusTbl, 0, row, "Level", text_color=stTextCol, text_size=size.tiny)
    table.cell(statusTbl, 1, row, "Data", text_color=stTextCol, text_size=size.tiny)
    row += 1

    // ——— ORB ——————————————————————————————————————————————————————————————

    string orbStatusVal = na(orbH) ? "WAIT" : stopped ? "BROKEN" : "OPEN"
    table.cell(statusTbl, 0, row, "ORB Status", text_color=stTextCol, text_size=size.tiny)
    table.cell(statusTbl, 1, row, orbStatusVal, text_color=stTextCol, text_size=size.tiny)
    row += 1

    string orbOp = orbBreakDir == 0 ? "-" : orbBreakDir == 1 ? "LONG" : "SHORT"
    table.cell(statusTbl, 0, row, "ORB Operation", text_color=stTextCol, text_size=size.tiny)
    table.cell(statusTbl, 1, row, orbOp, text_color=stTextCol, text_size=size.tiny)
    row += 1

    table.cell(statusTbl, 0, row, "ORB High", text_color=stTextCol, text_size=size.tiny)
    table.cell(statusTbl, 1, row, na(orbH) ? "-" : str.tostring(orbH, format.mintick), text_color=stTextCol, text_size=size.tiny)
    row += 1

    table.cell(statusTbl, 0, row, "ORB Low", text_color=stTextCol, text_size=size.tiny)
    table.cell(statusTbl, 1, row, na(orbL) ? "-" : str.tostring(orbL, format.mintick), text_color=stTextCol, text_size=size.tiny)
    row += 1

    table.cell(statusTbl, 0, row, "Broke Time", text_color=stTextCol, text_size=size.tiny)
    table.cell(statusTbl, 1, row, na(brokeTime) ? "-" : str.format_time(brokeTime, "HH:mm", NY), text_color=stTextCol, text_size=size.tiny)
    row += 1

    // ——— Candle ————————————————————————————————————————————————————————————

    table.cell(statusTbl, 0, row, "Candle Entry", text_color=stTextCol, text_size=size.tiny)
    table.cell(statusTbl, 1, row, na(candleEntry) ? "-" : str.tostring(candleEntry, format.mintick), text_color=stTextCol, text_size=size.tiny)
    row += 1

    table.cell(statusTbl, 0, row, "Candle Cover", text_color=stTextCol, text_size=size.tiny)
    table.cell(statusTbl, 1, row, na(candleCover) ? "-" : str.tostring(candleCover, format.mintick), text_color=stTextCol, text_size=size.tiny)
    row += 1

    table.cell(statusTbl, 0, row, "Candle Cover Hit", text_color=stTextCol, text_size=size.tiny)
    table.cell(statusTbl, 1, row, na(candleCoverHitTime) ? "-" : str.format_time(candleCoverHitTime, "HH:mm", NY), text_color=stTextCol, text_size=size.tiny)
    row += 1

    table.cell(statusTbl, 0, row, "Candle TP", text_color=stTextCol, text_size=size.tiny)
    table.cell(statusTbl, 1, row, na(candleTP) ? "-" : str.tostring(candleTP, format.mintick), text_color=stTextCol, text_size=size.tiny)
    row += 1

    table.cell(statusTbl, 0, row, "Candle TP Hit", text_color=stTextCol, text_size=size.tiny)
    table.cell(statusTbl, 1, row, na(candleTPHitTime) ? "-" : str.format_time(candleTPHitTime, "HH:mm", NY), text_color=stTextCol, text_size=size.tiny)
    row += 1

    // Compute FVG display values
    float fvgCoverVal = na
    float fvgExtVal   = na

    if stopped
        fvgCoverVal := snFvgCover
        fvgExtVal   := snFvgHasExt ? snFvgExt : na
    else if array.size(fvgBoxes) > 0
        int   last    = array.size(fvgBoxes) - 1
        float top     = array.get(fvgTops,    last)
        float bot     = array.get(fvgBots,    last)
        bool  isBull  = array.get(fvgIsBulls, last)
        line  extLine = array.get(fvgExtLines, last)

        fvgCoverVal := isBull ? bot - 0.25 : top + 0.25

        if not na(extLine)
            float extPrice = line.get_y1(extLine)
            fvgExtVal := isBull ? extPrice - 0.25 : extPrice + 0.25

    // ——— FVG ————————————————————————————————————————————————————————————————

    if not na(fvgCoverVal)
        table.cell(statusTbl, 0, row, "FVG Cover", text_color=stTextCol, text_size=size.tiny)
        table.cell(statusTbl, 1, row, str.tostring(fvgCoverVal, format.mintick), text_color=stTextCol, text_size=size.tiny)
        row += 1

        table.cell(statusTbl, 0, row, "FVG Cover Hit", text_color=stTextCol, text_size=size.tiny)
        table.cell(statusTbl, 1, row, na(fvgCoverHitTime) ? "-" : str.format_time(fvgCoverHitTime, "HH:mm", NY), text_color=stTextCol, text_size=size.tiny)
        row += 1

        table.cell(statusTbl, 0, row, "FVG TP", text_color=stTextCol, text_size=size.tiny)
        table.cell(statusTbl, 1, row, na(fvgTP) ? "-" : str.tostring(fvgTP, format.mintick), text_color=stTextCol, text_size=size.tiny)
        row += 1

        table.cell(statusTbl, 0, row, "FVG TP Hit", text_color=stTextCol, text_size=size.tiny)
        table.cell(statusTbl, 1, row, na(fvgTPHitTime) ? "-" : str.format_time(fvgTPHitTime, "HH:mm", NY), text_color=stTextCol, text_size=size.tiny)
        row += 1

    // ——— FVG Ext ————————————————————————————————————————————————————————————

    if not na(fvgExtVal)
        table.cell(statusTbl, 0, row, "FVG Ext Cover", text_color=stTextCol, text_size=size.tiny)
        table.cell(statusTbl, 1, row, str.tostring(fvgExtVal, format.mintick), text_color=stTextCol, text_size=size.tiny)
        row += 1

        table.cell(statusTbl, 0, row, "FVG Ext Cover Hit", text_color=stTextCol, text_size=size.tiny)
        table.cell(statusTbl, 1, row, na(fvgExtCoverHitTime) ? "-" : str.format_time(fvgExtCoverHitTime, "HH:mm", NY), text_color=stTextCol, text_size=size.tiny)
        row += 1

        table.cell(statusTbl, 0, row, "FVG EXT TP", text_color=stTextCol, text_size=size.tiny)
        table.cell(statusTbl, 1, row, na(fvgExtTP) ? "-" : str.tostring(fvgExtTP, format.mintick), text_color=stTextCol, text_size=size.tiny)
        row += 1

        table.cell(statusTbl, 0, row, "FVG EXT TP Hit", text_color=stTextCol, text_size=size.tiny)
        table.cell(statusTbl, 1, row, na(fvgExtTPHitTime) ? "-" : str.format_time(fvgExtTPHitTime, "HH:mm", NY), text_color=stTextCol, text_size=size.tiny)
        row += 1

    // Fill remaining rows
    if row <= 19
        for i = row to 19
            table.cell(statusTbl, 0, i, "", text_color=stTextCol, text_size=size.tiny)
            table.cell(statusTbl, 1, i, "", text_color=stTextCol, text_size=size.tiny)


// ─────────────────────────────────────────────────────────────────────────────
//  ALERTS
// ─────────────────────────────────────────────────────────────────────────────
alertcondition(barstate.isconfirmed and drawn and not stopped and close > orbH,
     "ORB Breakout Up",    "1-min close broke ABOVE ORB High")
alertcondition(barstate.isconfirmed and drawn and not stopped and close < orbL,
     "ORB Breakdown Down", "1-min close broke BELOW ORB Low")
