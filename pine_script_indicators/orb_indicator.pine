//@version=5
indicator("ORB — Opening Range Breakout [NY]", overlay=true,
          max_lines_count=500, max_labels_count=500)

// ─────────────────────────────────────────────────────────────────────────────
//  INPUTS
// ─────────────────────────────────────────────────────────────────────────────
var string G1 = "⏱  ORB Period  ·  All times: America / New_York"
var string G2 = "📐  Lines"
var string G3 = "🏷  Labels"
var string G4 = "🟦  Zone"

// ── ORB period ────────────────────────────────────────────────────────────────
i_orbPeriod = input.string(
     "5-min  (9:30 – 9:35)",
     "ORB Period",
     options  = ["5-min  (9:30 – 9:35)", "15-min  (9:30 – 9:45)"],
     tooltip  = "Captures the exact High / Low of the first candle of the NY session.\n• 5-min  → single 9:30–9:35 AM candle\n• 15-min → single 9:30–9:45 AM candle\nAll times are New York (America/New_York).",
     group    = G1)

// ── Lines ─────────────────────────────────────────────────────────────────────
i_highColor = input.color(color.new(#26a69a, 0), "High Line Color", group=G2)
i_lowColor  = input.color(color.new(#ef5350, 0), "Low Line Color",  group=G2)
i_lWidth    = input.int  (2, "Line Width", minval=1, maxval=4,       group=G2)
i_lStyle    = input.string("Solid", "Line Style",
     options = ["Solid","Dashed","Dotted"],                           group=G2)

// ── Labels ────────────────────────────────────────────────────────────────────
i_showLbl   = input.bool  (true,   "Show Labels",                    group=G3)
i_lblHText  = input.string("ORBH", "High Label Text",                group=G3)
i_lblLText  = input.string("ORBL", "Low Label Text",                 group=G3)
i_lblHPos   = input.string("Right","High Label H-Position",
     options = ["Left","Center","Right"],                             group=G3)
i_lblLPos   = input.string("Right","Low Label H-Position",
     options = ["Left","Center","Right"],                             group=G3)
i_lblVAlign = input.string("Middle","Label Vertical Alignment",
     options = ["Top","Middle","Bottom"],                             group=G3)
i_lblSize   = input.string("Small", "Label Size",
     options = ["Tiny","Small","Normal","Large"],                     group=G3)

// ── Zone ──────────────────────────────────────────────────────────────────────
i_showZone  = input.bool(true, "Show ORB Zone",                      group=G4)
i_zoneAlpha = input.int (90,   "Zone Transparency",
     minval=50, maxval=99,                                            group=G4)


// ─────────────────────────────────────────────────────────────────────────────
//  DERIVED CONSTANTS
// ─────────────────────────────────────────────────────────────────────────────
NY = "America/New_York"

// Minute at which the ORB window ends (exclusive)
orbEndMin = i_orbPeriod == "5-min  (9:30 – 9:35)"  ? 35  : 45


// ─────────────────────────────────────────────────────────────────────────────
//  HELPER FUNCTIONS
// ─────────────────────────────────────────────────────────────────────────────
f_ls() =>
    i_lStyle == "Dashed" ? line.style_dashed  :
     i_lStyle == "Dotted" ? line.style_dotted : line.style_solid

f_sz() =>
    i_lblSize == "Tiny"   ? size.tiny   :
     i_lblSize == "Normal" ? size.normal :
     i_lblSize == "Large"  ? size.large  : size.small

// Vertical placement of the label bubble relative to its anchor price
// label.style_label_down → pointer DOWN, body ABOVE anchor → visually "Top"
// label.style_label_up   → pointer UP,   body BELOW anchor → visually "Bottom"
f_vStyle() =>
    switch i_lblVAlign
        "Top"    => label.style_label_down     // body sits ABOVE the line
        "Bottom" => label.style_label_up       // body sits BELOW the line
        =>          label.style_label_center   // body centered ON the line

// Horizontal bar-index position for a label
f_lx(pos, s, e) =>
    switch pos
        "Left"   => s
        "Center" => math.round((s + e) / 2)
        =>          e   // Right


// ─────────────────────────────────────────────────────────────────────────────
//  CURRENT-BAR TIME  (chart timeframe, assumed 1-min)
// ─────────────────────────────────────────────────────────────────────────────
nyH = hour      (time, NY)
nyM = minute    (time, NY)
nyD = dayofmonth(time, NY)

// True while the current bar falls inside the ORB window (e.g. 9:30 – 9:34)
inORBWindow = nyH == 9 and nyM >= 30 and nyM < orbEndMin

// True on first bar AT OR AFTER the ORB window has closed
pastORB = (nyH == 9 and nyM >= orbEndMin) or nyH > 9


// ─────────────────────────────────────────────────────────────────────────────
//  PERSISTENT STATE
// ─────────────────────────────────────────────────────────────────────────────
var float    orbH            = na
var float    orbL            = na
var bool     drawn           = false
var bool     stopped         = false
var int      startBar        = na
var int      sessionStartBar = na    // bar_index of the 9:30 candle
var line     lnH             = na
var line     lnL             = na
var label    lbH             = na
var label    lbL             = na
var linefill zFill           = na


// ─────────────────────────────────────────────────────────────────────────────
//  RESET  ─  new trading day
// ─────────────────────────────────────────────────────────────────────────────
if ta.change(nyD)
    orbH            := na
    orbL            := na
    drawn           := false
    stopped         := false
    startBar        := na
    sessionStartBar := na
    lnH             := na
    lnL             := na
    lbH             := na
    lbL             := na
    zFill           := na


// ─────────────────────────────────────────────────────────────────────────────
//  STEP 0  —  Record the 9:30 bar_index (session open, before ORB closes)
// ─────────────────────────────────────────────────────────────────────────────
if nyH == 9 and nyM == 30 and na(sessionStartBar)
    sessionStartBar := bar_index


// ─────────────────────────────────────────────────────────────────────────────
//  STEP 1  —  Accumulate the ORB High / Low from each 1-min bar in the window
//  This replaces request.security so the indicator is fully deterministic
//  in replay mode (no HTF realtime-bar quirks).
// ─────────────────────────────────────────────────────────────────────────────
if inORBWindow and not drawn
    orbH := na(orbH) ? high : math.max(orbH, high)
    orbL := na(orbL) ? low  : math.min(orbL, low)


// ─────────────────────────────────────────────────────────────────────────────
//  STEP 2  —  Draw lines & labels (same bar as capture, runs right after)
// ─────────────────────────────────────────────────────────────────────────────
if pastORB and not drawn and not na(orbH) and not na(orbL)
    drawn    := true
    // Use the 9:30 bar as the visual start; fall back to current bar if missing
    startBar := not na(sessionStartBar) ? sessionStartBar : bar_index

    lnH := line.new(startBar, orbH, bar_index + 1, orbH,
         color=i_highColor, width=i_lWidth, style=f_ls(), extend=extend.right)
    lnL := line.new(startBar, orbL, bar_index + 1, orbL,
         color=i_lowColor,  width=i_lWidth, style=f_ls(), extend=extend.right)

    if i_showZone
        zFill := linefill.new(lnH, lnL, color.new(color.gray, i_zoneAlpha))

    if i_showLbl
        lbH := label.new(
             x         = startBar,
             y         = orbH,
             text      = i_lblHText,
             color     = chart.bg_color,
             textcolor = i_highColor,
             style     = f_vStyle(),
             size      = f_sz())
        lbL := label.new(
             x         = startBar,
             y         = orbL,
             text      = i_lblLText,
             color     = chart.bg_color,
             textcolor = i_lowColor,
             style     = f_vStyle(),
             size      = f_sz())


// ─────────────────────────────────────────────────────────────────────────────
//  STEP 3  —  Update label X positions every bar while lines are active
// ─────────────────────────────────────────────────────────────────────────────
if drawn and not stopped and i_showLbl
    if not na(lbH)
        label.set_x(lbH, f_lx(i_lblHPos, startBar, bar_index))
    if not na(lbL)
        label.set_x(lbL, f_lx(i_lblLPos, startBar, bar_index))


// ─────────────────────────────────────────────────────────────────────────────
//  STEP 4  —  Breakout detection: 1-min confirmed close crosses either level
//             → stop BOTH lines, freeze labels at final position
// ─────────────────────────────────────────────────────────────────────────────
if drawn and not stopped and barstate.isconfirmed
    if close > orbH or close < orbL
        stopped := true

        line.set_extend(lnH, extend.none)
        line.set_extend(lnL, extend.none)
        line.set_x2    (lnH, bar_index)
        line.set_x2    (lnL, bar_index)

        if i_showLbl
            if not na(lbH)
                label.set_x(lbH, f_lx(i_lblHPos, startBar, bar_index))
            if not na(lbL)
                label.set_x(lbL, f_lx(i_lblLPos, startBar, bar_index))


// ─────────────────────────────────────────────────────────────────────────────
//  ALERTS
// ─────────────────────────────────────────────────────────────────────────────
alertcondition(barstate.isconfirmed and drawn and not stopped and close > orbH,
     "ORB Breakout Up",    "1-min close broke ABOVE ORB High")
alertcondition(barstate.isconfirmed and drawn and not stopped and close < orbL,
     "ORB Breakdown Down", "1-min close broke BELOW ORB Low")